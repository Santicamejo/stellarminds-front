@model IEnumerable<StellarMindsWebApp.Models.Usuario.UsuarioModel>

@{
    ViewData["Title"] = "Index";
    string? rol = Context.Session.GetString("UsuarioLogeadoRol");
}

<h1>Index</h1>

@if (TempData["Error"] != null)
{
    <p class="text-danger">@TempData["Error"]</p>
}
@if (TempData["Exito"] != null)
{
    <p class="text-success">@TempData["Exito"]</p>
}

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Apellido)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Calle)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Numero)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Telefono)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.NombreUsuario)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Rol)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Nombre)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Apellido)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Calle)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Numero)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Telefono)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.NombreUsuario)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Rol)
            </td>
                @if (rol == "COORDINADOR")
                {
                    <td>
                        @Html.ActionLink("Prestamos", "PrestamosUsuario", "Prestamo", new { usuarioId = item.Id })
                    </td>
                }
        </tr>
}
    </tbody>
</table>

@if (rol == "ADMINISTRADOR")
{
    <p>
        <a asp-action="Crear">Agregar nuevo</a>
    </p>
}