@model IEnumerable<StellarMindsWebApp.Models.ObjetoCeleste.RankingObjetoCelesteModel>

@{
    ViewData["Title"] = "Ranking de objetos celestes";
}

<h1>Ranking de objetos celestes</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (Model != null && Model.Any())
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Posición</th>
                <th>Objeto celeste</th>
                <th>Cantidad de observaciones</th>
            </tr>
        </thead>
        <tbody>
            @{
                int posicion = 1;
            }

            @foreach (var item in Model)
            {
                <tr>
                    <td>@posicion</td>
                    <td>@item.Nombre</td>
                    <td>@item.CantidadObservaciones</td>
                </tr>

                posicion++;
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        Todavía no hay observaciones registradas para generar el ranking.
    </div>
}