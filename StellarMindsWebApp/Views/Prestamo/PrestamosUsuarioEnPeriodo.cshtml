@model IEnumerable<StellarMindsWebApp.Models.PrestamoModel.PrestamoModel>

@{
    ViewData["Title"] = "PrestamosUsuarioEnPeriodo";
}

<h1>Préstamos del usuario en período</h1>

<form asp-controller="Prestamo" asp-action="PrestamosUsuarioEnPeriodo" method="get" class="mb-4">

    <input type="hidden" name="usuarioId" value="@ViewBag.UsuarioId" />

    <div class="form-group">
        <label>Fecha inicio</label>
        <input type="date" name="inicio" class="form-control" value="@ViewBag.Inicio" />
    </div>

    <div class="form-group">
        <label>Fecha fin</label>
        <input type="date" name="fin" class="form-control" value="@ViewBag.Fin" />
    </div>

    <button type="submit" class="btn btn-primary mt-2">
        Buscar
    </button>
</form>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.IdPrestamo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Inicio)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Fin)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EquipoVisualId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EquipoVisualMarcaModelo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MonturaId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MonturaMarcaModelo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TelescopioId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TelescopioMarcaModelo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SocioId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SocioNombreApellido)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Estado)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.IdPrestamo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Inicio)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Fin)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EquipoVisualId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EquipoVisualMarcaModelo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MonturaId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MonturaMarcaModelo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TelescopioId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TelescopioMarcaModelo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SocioId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SocioNombreApellido)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Estado)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { /* id=item.PrimaryKey */ }) |
                @Html.ActionLink("Details", "Details", new { /* id=item.PrimaryKey */ }) |
                @Html.ActionLink("Delete", "Delete", new { /* id=item.PrimaryKey */ })
            </td>
        </tr>
}
    </tbody>
</table>
