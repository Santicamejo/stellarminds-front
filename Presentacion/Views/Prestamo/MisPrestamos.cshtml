@model IEnumerable<DTOs.DTOs.Prestamo.PrestamoDTO>

@{
    ViewData["Title"] = "Mis préstamos";
}

<h1>Mis préstamos</h1>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">
        @ViewBag.ErrorMessage
    </div>
}

<form asp-action="MisPrestamos" asp-controller="Prestamo" method="post" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <label for="inicio" class="form-label">Fecha de inicio</label>
            <input type="date" id="inicio" name="inicio" class="form-control" required />
        </div>

        <div class="col-md-4">
            <label for="fin" class="form-label">Fecha de fin</label>
            <input type="date" id="fin" name="fin" class="form-control" required />
        </div>

        <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-primary">
                Buscar préstamos
            </button>
        </div>
    </div>
</form>

@if (Model != null && Model.Any())
{
    <table class="table table-striped table-bordered">
        <thead>
        <tr>
            <th>Id</th>
            <th>Inicio</th>
            <th>Fin</th>
            <th>Telescopio</th>
            <th>Montura</th>
            <th>Equipo visual</th>
            <th>Estado</th>
        </tr>
        </thead>

        <tbody>
        @foreach (var prestamo in Model)
        {
            <tr>
                <td>@prestamo.IdPrestamo</td>
                <td>@prestamo.Inicio.ToShortDateString()</td>
                <td>@prestamo.Fin.ToShortDateString()</td>
                <td>@prestamo.TelescopioId</td>
                <td>@prestamo.MonturaId</td>
                <td>@prestamo.EquipoVisualId</td>
                <td>@prestamo.Estado</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No hay préstamos para mostrar.</p>
}