@using System.Globalization
@model DTOs.DTOs.Equipo.AltaMonturaDTO

@{
    ViewData["Title"] = "CreateMontura";
}

<h1>CreateMontura</h1>

<h4>AltaMonturaDTO</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="CreateMontura">
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger" role="alert">
                    @ViewBag.ErrorMessage
                </div>
            }
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="TipoMontura" class="control-label">Tipo Montura</label>
                <select asp-for="TipoMontura" class="form-control">
                    <option value="" disabled selected hidden>Seleccione un tipo de montura</option>
                    <option value="0">Ecuatorial</option>
                    <option value="1">AltAzimutal</option>
                    <option value="2">Hibrida</option>
                </select>
                <span asp-validation-for="TipoMontura" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CargaUtil" class="control-label">Carga Util</label>
                <input asp-for="CargaUtil"
                       class="form-control"
                       type="number"
                       step="any" />
                <span asp-validation-for="CargaUtil" class="text-danger"></span>
            </div>

            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="EsComputarizada" />
                    Computarizada
                </label>
            </div>

            <div class="form-group">
                <label asp-for="Marca" class="control-label">Marca</label>
                <input asp-for="Marca" class="form-control" />
                <span asp-validation-for="Marca" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Modelo" class="control-label">Modelo</label>
                <input asp-for="Modelo" class="form-control" />
                <span asp-validation-for="Modelo" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CantidadDisponible" class="control-label">Stock</label>
                <input asp-for="CantidadDisponible" class="form-control" type="number" step="1" />
                <span asp-validation-for="CantidadDisponible" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
