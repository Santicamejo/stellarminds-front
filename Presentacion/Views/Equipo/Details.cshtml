@using DTOs.DTOs.Equipo

@model DTOs.DTOs.Equipo.EquipoDTO

@{
    ViewData["Title"] = "Detalles del equipo";
}

<h1>@Model.Modelo</h1>

<div>
    <h4>Datos generales</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">Modelo</dt>
        <dd class="col-sm-10">@Model.Modelo</dd>

        <dt class="col-sm-2">Marca</dt>
        <dd class="col-sm-10">@Model.Marca</dd>

        <dt class="col-sm-2">ID</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">Cantidad disponible</dt>
        <dd class="col-sm-10">@Model.CantidadDisponible Unidades</dd>
    </dl>

    <h4>Datos específicos</h4>
    <hr />

    @switch (Model)
    {
        case TelescopioDTO telescopio:
            <dl class="row">
                <dt class="col-sm-2">Apertura</dt>
                <dd class="col-sm-10">@telescopio.Apertura mm</dd>

                <dt class="col-sm-2">Relación focal</dt>
                <dd class="col-sm-10">@telescopio.RelacionFocal</dd>

                <dt class="col-sm-2">Distancia focal</dt>
                <dd class="col-sm-10">@telescopio.DistanciaFocal mm</dd>

                <dt class="col-sm-2">Peso</dt>
                <dd class="col-sm-10">@telescopio.Peso Kg</dd>
            </dl>
            break;

        case MonturaDTO montura:
            <dl class="row">
                <dt class="col-sm-2">Tipo de montura</dt>
                <dd class="col-sm-10">@montura.TipoMontura</dd>

                <dt class="col-sm-2">Carga útil</dt>
                <dd class="col-sm-10">@montura.CargaUtil Kg</dd>

                <dt class="col-sm-2">Computarizada</dt>
                @if (montura.EsComputarizada)
                {
                    <dd class="col-sm-10">Si</dd>
                }
                else
                {
                    <dd class="col-sm-10">No</dd>
                }
            </dl>
            break;

        case CamaraDTO camara:
            <dl class="row">
                <dt class="col-sm-2">Tipo de sensor</dt>
                <dd class="col-sm-10">@camara.TipoSensor</dd>

                <dt class="col-sm-2">Resolución</dt>
                <dd class="col-sm-10">@camara.Resolucion</dd>

                <dt class="col-sm-2">Tamaño de pixel</dt>
                <dd class="col-sm-10">@camara.TamanoPixel Um</dd>
            </dl>
            break;

        case OcularDTO ocular:
            <dl class="row">
                <dt class="col-sm-2">Diámetro</dt>
                <dd class="col-sm-10">@ocular.Diametro mm</dd>

                <dt class="col-sm-2">Ángulo de visión</dt>
                <dd class="col-sm-10">@ocular.AnguloVision°</dd>

                <dt class="col-sm-2">Estado</dt>
            </dl>
            break;
    }
</div>

<div>
    <a asp-action="Index">Volver al listado</a>
</div>